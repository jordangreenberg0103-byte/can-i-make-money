<script>

function generatePrompt(){

const idea =
document.getElementById("idea").value;

const location =
document.getElementById("location").value;

const budget =
document.getElementById("budget").value;

const prompt =

`You are an expert business analyst.

Analyze this business idea using current internet information when available.

Business Idea:
${idea}

Location:
${location}

Startup Budget:
$${budget}

Provide:

1. Overall Business Score (0-100)
2. Profit Potential Score (0-100)
3. Competition Score (0-100)
4. Scalability Score (0-100)
5. Startup Difficulty Score (0-100)

6. Revenue Forecast
- Low Case
- Expected Case
- High Case

7. SWOT Analysis

8. Top 5 Risks

9. Top 5 Opportunities

10. Executive Summary

Format all scores clearly and explain reasoning.`;

document.getElementById("prompt").value =
prompt;

}

function copyPrompt(){

const text =
document.getElementById("prompt");

text.select();

navigator.clipboard.writeText(text.value);

alert("Prompt copied!");

}

function openGoogleAI(){

window.open(
"https://www.google.com/search?q=Google+AI+Mode",
"_blank"
);

}

function randomScore(min,max){

return Math.floor(
Math.random()*(max-min+1)
)+min;

}

function showReport(){

const report =
document.getElementById("aiReport").value;

document.getElementById("output").textContent =
report;

document.getElementById("overallScore").textContent =
randomScore(70,95);

document.getElementById("profitScore").textContent =
randomScore(65,95);

document.getElementById("competitionScore").textContent =
randomScore(50,90);

document.getElementById("scaleScore").textContent =
randomScore(60,95);

}

</script>

